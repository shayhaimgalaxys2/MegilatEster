<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/quiz_primary_light" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="@color/quiz_primary" />
            <padding android:bottom="8dp" android:start="8dp" android:end="8dp" android:top="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/quiz_option_unselected_bg" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/quiz_option_unselected_stroke" />
            <padding android:bottom="8dp" android:start="8dp" android:end="8dp" android:top="8dp" />
        </shape>
    </item>
</selector>
