<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="-9dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="-9dp"
        android:layout_weight="488"
        android:background="@drawable/scroll_background"
        android:orientation="vertical">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/autoScrollBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_auto_scroll_button"
                android:contentDescription="@string/a11y_auto_scroll"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_auto_scroll"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/purimSongsButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_main_chip"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/purim_songs"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/blessingsTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_main_chip"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/megilla_blessings"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <com.mobilegiants.megila.v2.custom_views.InteractiveScrollView
            android:id="@+id/myscrollview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="48dp">

            <TextView
                android:id="@+id/myTextViewTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="38dp"
                android:layout_marginBottom="24dp"
                android:keepScreenOn="true"
                android:textColor="@color/black"
                android:textSize="@dimen/_19ssp"
                tools:fontFamily="@font/shlomo_stam"
                tools:text="@string/first_chapter" />
        </com.mobilegiants.megila.v2.custom_views.InteractiveScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_8sdp"
        android:layout_marginBottom="@dimen/_8sdp"
        android:layout_weight="40"
        android:background="@color/main_bottom_bar_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_bottom_bar_item"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/lawsBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/a11y_quiz"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_purim_quiz" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_bottom_bar_item"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/rahashanBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/a11y_noisemaker"
                android:scaleType="fitCenter"
                android:src="@drawable/noisemaker1" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_bottom_bar_item"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/gunfireBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/a11y_gunfire"
                android:scaleType="fitCenter"
                android:src="@drawable/gun64" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_bottom_bar_item"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/grenadeBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/a11y_grenade"
                android:scaleType="fitCenter"
                android:src="@drawable/grenade64" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
