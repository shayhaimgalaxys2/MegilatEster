<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:layoutDirection="locale"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_header"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/blessings_dialog_title"
            android:textColor="@color/dialog_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:background="@color/dialog_title" />

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:scrollbarThumbVertical="@drawable/bg_dialog_scrollbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="8dp">

            <!-- Before reading section -->
            <TextView
                android:id="@+id/beforeReadingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/blessings_before_title"
                android:textColor="@color/dialog_subtitle"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/beforeReadingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:layoutDirection="rtl"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/dialog_text"
                android:textDirection="rtl"
                android:textSize="17sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="@color/dialog_divider" />

            <!-- After reading section -->
            <TextView
                android:id="@+id/afterReadingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/blessings_after_title"
                android:textColor="@color/dialog_subtitle"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/afterReadingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:layoutDirection="rtl"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/dialog_text"
                android:textDirection="rtl"
                android:textSize="17sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Close button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:padding="12dp"
        android:text="@string/blessings_dialog_close"
        android:textColor="@color/dialog_button_text"
        android:textSize="16sp"
        app:backgroundTint="@color/dialog_button_bg"
        app:cornerRadius="25dp" />

</LinearLayout>
