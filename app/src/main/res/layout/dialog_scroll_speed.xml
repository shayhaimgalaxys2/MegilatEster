<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_scroll_dialog_title"
        android:textColor="@color/dialog_title"
        android:textSize="20sp"
        android:textStyle="bold" />

    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:layout_marginTop="8dp"
        android:background="@color/dialog_title" />

    <!-- Speed grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/speedGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/auto_scroll_dialog_cancel"
            android:textColor="@color/dialog_button_outline_text"
            app:cornerRadius="25dp"
            app:strokeColor="@color/dialog_button_outline_text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/auto_scroll_dialog_confirm"
            android:textColor="@color/dialog_button_text"
            app:backgroundTint="@color/dialog_button_bg"
            app:cornerRadius="25dp" />

    </LinearLayout>

</LinearLayout>
